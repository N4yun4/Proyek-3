{
  "name": "monitoring-app",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "build": "bun run --cwd apps/frontend build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
